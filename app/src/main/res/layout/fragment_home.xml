<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/swipe_refresh"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- ── Wallet Balance Card ──────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_balance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="@color/primary">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Header row: coin name + sync indicator -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="996coin Wallet"
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp"
                            android:letterSpacing="0.08" />

                        <!-- Sync status pill -->
                        <LinearLayout
                            android:id="@+id/sync_status_container"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:background="@drawable/bg_pill_sync"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="4dp"
                            android:paddingBottom="4dp">

                            <View
                                android:id="@+id/sync_dot"
                                android:layout_width="6dp"
                                android:layout_height="6dp"
                                android:background="@drawable/bg_sync_dot"
                                android:layout_marginEnd="5dp" />

                            <TextView
                                android:id="@+id/tv_sync_status"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/sync_done"
                                android:textColor="#FFFFFF"
                                android:textSize="11sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Balance -->
                    <TextView
                        android:id="@+id/tv_balance_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="@string/balance_label"
                        android:textColor="#AAFFFFFF"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/tv_balance_nns"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="0.00000000 NNS"
                        android:textColor="#FFFFFF"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        tools:text="1,234.56780000 NNS" />

                    <TextView
                        android:id="@+id/tv_balance_usd"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="≈ $0.00 USD"
                        android:textColor="#CCFFFFFF"
                        android:textSize="15sp"
                        tools:text="≈ $12.34 USD" />

                    <!-- Pending balance row -->
                    <LinearLayout
                        android:id="@+id/pending_row"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp"
                        android:visibility="gone">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="⏳ Pending: "
                            android:textColor="#AAFFFFFF"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_pending"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="#AAFFFFFF"
                            android:textSize="12sp"
                            tools:text="2.5 NNS" />
                    </LinearLayout>

                    <!-- Separator -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="16dp"
                        android:background="#33FFFFFF" />

                    <!-- Address row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:id="@+id/tv_address"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:ellipsize="middle"
                            android:singleLine="true"
                            android:text="N..."
                            android:textColor="#CCFFFFFF"
                            android:textSize="13sp"
                            android:fontFamily="monospace"
                            tools:text="NQK5Xh7NjMoJ1sSmHjCbpTpKXqrCdBJgW" />

                        <ImageButton
                            android:id="@+id/btn_copy_address"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:background="?attr/selectableItemBackgroundBorderless"
                            android:src="@drawable/ic_copy"
                            android:tint="#CCFFFFFF"
                            android:contentDescription="Copy address" />
                    </LinearLayout>

                    <!-- Sync progress bar -->
                    <ProgressBar
                        android:id="@+id/sync_progress"
                        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="4dp"
                        android:layout_marginTop="12dp"
                        android:progressTint="#FFFFFF"
                        android:progressBackgroundTint="#44FFFFFF"
                        android:max="100"
                        android:progress="0"
                        android:visibility="gone" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Price Card ──────────────────────────────────────────── -->
            <androidx.cardview.widget.CardView
                android:id="@+id/card_price"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="?attr/colorSurface">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Price header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="NNS / USDT"
                            android:textColor="@color/text_secondary"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tv_price_source"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Klingex"
                            android:textColor="@color/text_hint"
                            android:textSize="11sp" />
                    </LinearLayout>

                    <!-- Price value row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/tv_price_usd"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="$0.000000"
                            android:textColor="@color/text_primary"
                            android:textSize="26sp"
                            android:textStyle="bold"
                            tools:text="$0.002345" />

                        <TextView
                            android:id="@+id/tv_price_change"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="+0.00%"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:paddingStart="10dp"
                            android:paddingEnd="10dp"
                            android:paddingTop="5dp"
                            android:paddingBottom="5dp"
                            android:background="@drawable/bg_pill_green"
                            tools:text="+2.45%" />
                    </LinearLayout>

                    <!-- High / Low row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">

                        <TextView
                            android:id="@+id/tv_high_24h"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="H: —"
                            android:textColor="@color/accent_green"
                            android:textSize="12sp"
                            tools:text="H: $0.00250" />

                        <TextView
                            android:id="@+id/tv_low_24h"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="L: —"
                            android:textColor="@color/accent_red"
                            android:textSize="12sp"
                            tools:text="L: $0.00210" />

                        <TextView
                            android:id="@+id/tv_volume_24h"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Vol: —"
                            android:textColor="@color/text_secondary"
                            android:textSize="12sp"
                            tools:text="Vol: 12,340" />
                    </LinearLayout>

                    <!-- MPAndroidChart line chart -->
                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/price_chart"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/chart_height"
                        android:layout_marginTop="12dp" />

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- ── Quick Actions ──────────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_send"
                    style="@style/Widget.996Wallet.Button.Primary"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="↑ Send"
                    app:icon="@drawable/ic_send"
                    app:iconGravity="textStart" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_receive"
                    style="@style/Widget.996Wallet.Button.Outlined"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="↓ Receive"
                    app:icon="@drawable/ic_receive"
                    app:iconGravity="textStart" />
            </LinearLayout>

            <!-- ── Recent Transactions ────────────────────────────────── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Recent Transactions"
                    android:textColor="@color/text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_see_all"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See all →"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:padding="4dp" />
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_recent_transactions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:nestedScrollingEnabled="false"
                tools:itemCount="3"
                tools:listitem="@layout/item_transaction" />

            <!-- Empty state -->
            <LinearLayout
                android:id="@+id/empty_transactions"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="32dp"
                android:visibility="gone">

                <ImageView
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:src="@drawable/ic_history"
                    android:alpha="0.3" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/history_empty"
                    android:textColor="@color/text_hint"
                    android:textSize="14sp" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
