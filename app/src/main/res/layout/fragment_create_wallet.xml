<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:scrollbars="none"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Step indicator -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 1 of 3"
            android:textColor="@color/primary"
            android:textSize="13sp"
            android:textStyle="bold"
            android:background="@drawable/bg_pill_orange"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/setup_seed_title"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <!-- Warning banner -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_warning_banner"
            android:padding="14dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="20dp">

            <TextView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:text="⚠️"
                android:textSize="16sp"
                android:layout_marginEnd="10dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/setup_seed_warning"
                android:textColor="#7A4A00"
                android:textSize="13sp"
                android:lineSpacingMultiplier="1.3" />
        </LinearLayout>

        <!-- 12-word grid (2 columns × 6 rows) -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_seed_words"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false" />

        <!-- Copy all button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_copy_seed"
            style="@style/Widget.996Wallet.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="16dp"
            android:text="Copy All Words"
            app:icon="@drawable/ic_copy" />

        <!-- Confirm checkbox -->
        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/cb_written_down"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/setup_seed_confirm"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <!-- Next button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_next"
            style="@style/Widget.996Wallet.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:text="@string/btn_next"
            android:enabled="false" />

    </LinearLayout>
</ScrollView>
