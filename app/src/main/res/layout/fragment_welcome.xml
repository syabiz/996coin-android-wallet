<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center_horizontal"
    android:background="@color/background_dark">

    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

    <ImageView
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:src="@mipmap/ic_launcher"
        android:contentDescription="@string/app_name" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:text="@string/setup_welcome"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary"
        android:gravity="center"
        android:lineSpacingMultiplier="1.2" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginStart="40dp"
        android:layout_marginEnd="40dp"
        android:text="@string/app_tagline"
        android:textColor="@color/text_primary"
        android:alpha="0.8"
        android:textSize="15sp"
        android:gravity="center" />

    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="44dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_create_wallet"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/setup_create_address"
            android:textColor="@color/text_button_active"
            android:backgroundTint="@color/button_active"
            app:cornerRadius="14dp"
            android:textSize="15sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_import_wif"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:text="@string/setup_import_wif_btn"
            android:textColor="@color/text_primary"
            android:backgroundTint="@color/button_inactive"
            app:cornerRadius="14dp"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_gravity="center"
            android:text="@string/setup_import_wif_desc"
            android:textColor="@color/text_primary"
            android:alpha="0.7"
            android:textSize="13sp"
            android:gravity="center" />

    </LinearLayout>
</LinearLayout>
