<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Coin996Wallet" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorSecondary">@color/accent_green</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:statusBarColor">@color/primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:fontFamily">@font/nunito</item>
    </style>

    <!-- Splash theme (windowBackground is the splash drawable) -->
    <style name="Theme.Coin996Wallet.Splash" parent="Theme.Coin996Wallet">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:statusBarColor">@color/primary</item>
    </style>

    <!-- Card style -->
    <style name="Widget.996Wallet.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- Balance card (gradient orange) -->
    <style name="Widget.996Wallet.Card.Balance" parent="Widget.996Wallet.Card">
        <item name="cardBackgroundColor">@color/primary</item>
        <item name="cardElevation">8dp</item>
    </style>

    <!-- Primary button -->
    <style name="Widget.996Wallet.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/on_primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/nunito_bold</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <!-- Outlined button -->
    <style name="Widget.996Wallet.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/nunito_semibold</item>
    </style>

    <!-- Text input -->
    <style name="Widget.996Wallet.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- PIN numpad key -->
    <style name="Widget.996Wallet.PinKey" parent="Widget.Material3.Button.TextButton">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">100dp</item>
        <item name="rippleColor">@color/primary_light</item>
        <item name="android:layout_margin">4dp</item>
    </style>

    <!-- Bottom navigation -->
    <style name="Widget.996Wallet.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@drawable/bottom_nav_icon_tint</item>
        <item name="itemTextColor">@drawable/bottom_nav_icon_tint</item>
        <item name="labelVisibilityMode">labeled</item>
        <item name="elevation">8dp</item>
    </style>

</resources>
