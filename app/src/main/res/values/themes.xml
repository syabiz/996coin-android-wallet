<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Main Theme (Dark Aesthetic like the Generator) -->
    <style name="Theme.Coin996Wallet" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorOnPrimary">@color/text_button_active</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/background</item>
        <item name="android:fontFamily">@font/nunito</item>
    </style>

    <!-- Splash theme -->
    <style name="Theme.Coin996Wallet.Splash" parent="Theme.Coin996Wallet">
        <item name="android:windowBackground">@drawable/splash_background</item>
    </style>

    <!-- Card style -->
    <style name="Widget.996Wallet.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="contentPadding">16dp</item>
        <item name="cardBackgroundColor">@color/background_card</item>
    </style>

    <!-- Balance card (Gradient Blue) -->
    <style name="Widget.996Wallet.Card.Balance" parent="Widget.996Wallet.Card">
        <item name="cardBackgroundColor">@android:color/transparent</item>
        <item name="cardElevation">8dp</item>
    </style>

    <!-- Primary button -->
    <style name="Widget.996Wallet.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/button_active</item>
        <item name="android:textColor">@color/text_button_active</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/nunito_bold</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <!-- Inactive button style (if used) -->
    <style name="Widget.996Wallet.Button.Inactive" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/button_inactive</item>
        <item name="android:textColor">@color/text_button_inactive</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <!-- Outlined button -->
    <style name="Widget.996Wallet.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">16sp</item>
        <item name="android:fontFamily">@font/nunito_semibold</item>
    </style>

    <!-- Text input -->
    <style name="Widget.996Wallet.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/text_secondary</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
    </style>

    <!-- PIN Pad Button -->
    <style name="Widget.996Wallet.PinKey" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">24sp</item>
        <item name="android:fontFamily">@font/nunito_bold</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="rippleColor">#3300C0FA</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="Widget.996Wallet.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="itemIconTint">@color/primary</item>
        <item name="itemTextColor">@color/text_secondary</item>
        <item name="android:background">@color/surface</item>
    </style>

</resources>
